# GitHub Personal Access Token (ghp_ or github_pat_ prefix)
GITHUB_TOKEN=your_github_token_here

# Project display name (supports spaces, leading/trailing trimmed)
OBSERVER_NAME=Observer Beacon

# GitHub repo to monitor (owner/repo format)
OBSERVER_REPO=BeaconCat/observer-beacon

# Password for manual update trigger
OBSERVER_PASSWORD=pl3ase_ch@nge_m3

# Accent color for title hover glow (hex, must quote the #)
OBSERVER_ACCENT="#00d4ff"

# Auto-fetch interval in minutes (default 30, aligns to clock: 30 → :00/:30, 10 → :00/:10/:20/...)
OBSERVER_INTERVAL=30

# Manual update cooldown in minutes (default 5)
OBSERVER_MANUAL_INTERVAL=5

# Skip next auto-fetch after a manual update (default true)
OBSERVER_SKIP_CRON_AFTER_MANUAL=true

# Server port
PORT=3175
